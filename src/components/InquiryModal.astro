<!-- Inquiry Modal -->
<div id="inquiry-modal" class="hidden fixed inset-0 z-[100] items-center justify-center bg-slate-950/80 backdrop-blur-sm p-4">
  <div class="modal-animate relative max-w-lg w-full bg-slate-900 border border-white/10 rounded-3xl p-8 shadow-2xl">
    <button onclick="document.getElementById('inquiry-modal').classList.add('hidden'); document.getElementById('inquiry-modal').classList.remove('flex')"
            class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center transition-colors">
      <i class="fa-solid fa-times text-slate-400"></i>
    </button>

    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-cyan-400/10 flex items-center justify-center mx-auto mb-5">
        <i class="fa-solid fa-envelope text-3xl text-cyan-400"></i>
      </div>
      <h3 class="text-2xl font-display font-bold tracking-tight mb-2">Acquire hvacr.contact</h3>
      <p class="text-slate-400 text-sm">This is a premium domain for serious buyers only. All inquiries are confidential.</p>
    </div>

    <div class="border border-white/5 rounded-2xl p-5 mb-6 bg-slate-950">
      <div class="text-xs font-semibold text-slate-400 mb-1">Domain</div>
      <div class="text-xl font-mono font-bold">hvacr.contact</div>
      <div class="border-t border-white/5 my-3"></div>
      <div class="text-xs font-semibold text-slate-400 mb-1">Asking Price</div>
      <div class="text-2xl font-display font-bold text-cyan-400">$39,500</div>
    </div>

    <a href="mailto:sales@desertrich.com?subject=Inquiry%20for%20hvacr.contact%20acquisition"
       class="w-full flex items-center justify-center gap-x-3 px-8 py-4 rounded-3xl bg-cyan-400 hover:bg-white text-slate-950 font-semibold text-lg transition-all active:scale-[0.985] shadow-lg shadow-cyan-400/20">
      <i class="fa-solid fa-envelope"></i>
      <span>Email: sales@desertrich.com</span>
    </a>

    <p class="text-center text-[10px] text-slate-500 mt-5">Preferred closing via Escrow.com or DAN.com. Transfer in 1–5 business days.</p>
  </div>
</div>

<script>
  // Close modal on backdrop click
  const modal = document.getElementById('inquiry-modal');
  modal?.addEventListener('click', function(e) {
    if (e.target === modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  });

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    }
  });
</script>
