  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <div class="flex items-center gap-x-3">
        <div class="w-9 h-9 bg-emerald-600 rounded-xl flex items-center justify-center">
          <i class="fa-solid fa-snowflake text-white text-lg"></i>
        </div>
        <div>
          <span class="font-display text-2xl font-semibold tracking-tighter">hvacr</span>
          <span class="font-display text-2xl font-semibold tracking-tighter text-cyan-400">.contact</span>
        </div>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center gap-x-9 text-sm font-medium">
        <a href="#why" class="nav-link text-slate-300 hover:text-white">Why This Domain</a>
        <a href="#buyers" class="nav-link text-slate-300 hover:text-white">Ideal Buyers</a>
        <a href="#acquire" class="nav-link text-slate-300 hover:text-white">Acquire</a>
      </div>

      <div class="flex items-center gap-x-4">
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn"
                class="md:hidden w-10 h-10 flex items-center justify-center text-slate-400 hover:text-white transition-colors"
                aria-label="Toggle menu">
          <i class="fa-solid fa-bars text-xl"></i>
        </button>

        <!-- CTA Button -->
        <a href="#acquire"
           class="hidden md:flex items-center gap-x-2 px-6 py-2.5 rounded-2xl bg-white text-slate-950 hover:bg-cyan-400 hover:text-slate-950 transition-all font-semibold text-sm shadow-lg shadow-white/10 active:scale-[0.985]">
          <span>Inquire Now</span>
        </a>
      </div>
